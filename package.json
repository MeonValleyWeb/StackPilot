{
  "name": "stackpilot",
  "version": "0.1.0",
  "description": "A terminal control plane for managing sites across providers.",
  "type": "module",
  "bin": {
    "stackpilot": "./src/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "start": "bun run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "link-global": "bun link",
    "unlink-global": "bun unlink",
    "build:binary": "bun build src/index.tsx --compile --outfile stackpilot"
  },
  "keywords": [
    "stackpilot",
    "tui",
    "terminal-ui",
    "opentui",
    "devops"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
